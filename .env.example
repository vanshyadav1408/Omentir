# Self-hosted mode
RUN_LOCALLY=TRUE
APP_BASE_URL=http://localhost:3000
# Required unless LOCAL_ALLOW_OPEN_ACCESS=true (explicit opt-in for a welcome button).
LOCAL_APP_PASSWORD=
# LOCAL_ALLOW_OPEN_ACCESS=true
# Required. Generate a unique value before startup; blank values fail validation.
LOCAL_SESSION_SECRET=
LOCAL_USER_NAME=Local User
LOCAL_USER_EMAIL=local@localhost

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# Unipile
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=

# Gemini. Use this simple API-key path, or remove it and configure Vertex below.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Automation starts in dry-run unless this is explicitly true.
CRON_SECRET=
ENABLE_LIVE_AUTOMATION=false
# AUTOMATION_DISABLED=true

# Optional transactional notifications (self-host: your Resend account)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Your App <notifications@example.com>

# Extra origins allowed to reach the Next dev server for HMR / dev resources.
# localhost and 127.0.0.1 are always allowed. Add this only if you run `next dev`
# behind a proxy or tunnel and open the app on that hostname — otherwise Next
# blocks the HMR socket and the app never hydrates (buttons stop responding).
# Comma-separated, hostname only (no scheme). Example:
# ALLOWED_DEV_ORIGINS=dev.example.com,my-tunnel.example.net

# Hosted cloud only (omentir.com). Defaults match production brand identity.
# Self-host never needs these — leave unset.
# HOSTED_SUPPORT_EMAIL=hi@omentir.com
# HOSTED_CONTACT_EMAIL=vansh@omentir.com
# HOSTED_CONTACT_FORM_TO=vansh@omentir.com
# HOSTED_NEW_SIGNUP_TO=notifications@omentir.com
